<%- include('partials/header') %>

<div class="container">

    <h1>Produtos</h1>

    <div class="crudContainer">
        <div class="formArea">
            <h2><%= produtoEditar ? 'Editar Produto' : 'Novo Produto'%></h2>

            <form action="<%= produtoEditar ? '/produtos/editar/'+produtoEditar._id : '/produtos/adicionar'%>" method="POST">
                <input name="nome" placeholder="Nome" value="<%= produtoEditar?.nome || '' %>">

                <input name="preco" placeholder="Preço" value="<%= produtoEditar?.preco || '' %>">

                <input name="categoria" placeholder="Categoria" value="<%= produtoEditar?.categoria || '' %>">

                <textarea name="descricao" placeholder="Descrição"><%= produtoEditar?.descricao || '' %></textarea>

                <button><%= produtoEditar ? 'Salvar' : 'Cadastrar'%></button>
            </form>
        </div>

        <div class="listaArea">
            <% produtos.forEach(p=>{ %>

            <div class="produtoCard">
                <h3><%= p.nome %></h3>

                <p>R$ <%= p.preco %></p>

                <p><%= p.categoria %></p>

                <div>
                    <a href="/produtos/editar/<%= p._id %>">Editar</a>

                    <a href="/produtos/excluir/<%= p._id %>">Excluir</a>
                </div>
            </div>

            <% }) %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>